# ─────────────────────────────────────────────────────────────
# .env.example - Holehe OSINT REST API Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# Optional: Protect your API with a key.
# If set, all requests must include:
#   Header: X-API-Key: your-secret-key
#   OR query: ?api_key=your-secret-key
# Leave empty to allow public access.
API_KEY=

# Host and port for local development
HOST=0.0.0.0
PORT=8000

# Enable Flask debug mode (set to 'false' in production!)
DEBUG=false

# Maximum seconds to wait for each platform to respond
TIMEOUT=15
